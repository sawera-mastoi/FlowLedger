{
  "name": "flowledger-dapp",
  "private": true,
  "description": "Monorepo for the FlowLedger ecosystem on Stacks. Built for the Stacks April Builder Challenge.",
  "scripts": {
    "dev": "npx serve packages/flowledger-dapp",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "boost:downloads": "powershell ./boost_downloads.ps1",
    "boost:commits": "node boost_100_quality_commits.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "author": "earnwithalee",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sawera-mastoi/FlowLedger.git"
  },
  "bugs": {
    "url": "https://github.com/sawera-mastoi/FlowLedger/issues"
  },
  "homepage": "https://github.com/sawera-mastoi/FlowLedger#readme",
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@earnwithalee/flowledger-sdk": "^1.0.2",
    "stacks-echo-kit": "^1.0.0"
  }
}
